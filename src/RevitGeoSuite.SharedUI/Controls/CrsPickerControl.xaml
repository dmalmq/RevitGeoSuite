<UserControl x:Class="RevitGeoSuite.SharedUI.Controls.CrsPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RevitGeoSuite.SharedUI.Controls"
             xmlns:converters="clr-namespace:RevitGeoSuite.SharedUI.Converters">
  <UserControl.Resources>
    <converters:CrsDisplayConverter x:Key="CrsDisplayConverter" />
  </UserControl.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="16" />
      <ColumnDefinition Width="3*" />
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0">
      <TextBlock FontSize="16" FontWeight="SemiBold" Text="Coordinate Reference System" />
      <TextBlock Margin="0,4,0,8" Foreground="#5C6670" Text="Search by EPSG code, zone, or place name." />
      <TextBox x:Name="SearchBox" Margin="0,0,0,8" TextChanged="OnSearchTextChanged" />
      <ListBox x:Name="DefinitionsList"
               MinHeight="280"
               ItemsSource="{Binding FilteredDefinitions, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}"
               SelectedItem="{Binding SelectedDefinition, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}, Mode=TwoWay}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,2">
              <TextBlock FontWeight="SemiBold" Text="{Binding Converter={StaticResource CrsDisplayConverter}}" TextWrapping="Wrap" />
              <TextBlock Foreground="#5C6670" Text="{Binding AreaSummary}" TextWrapping="Wrap" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <Border Grid.Column="2" Padding="14" Background="#FFFDF9" BorderBrush="#D7D0C2" BorderThickness="1" CornerRadius="6">
      <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Selected CRS" />
        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="{Binding SelectedDefinition.Name, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}, FallbackValue=Select a CRS}" TextWrapping="Wrap" />
        <TextBlock Margin="0,6,0,0" Text="{Binding SelectedDefinition.EpsgCode, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}" />
        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Area" />
        <TextBlock Text="{Binding SelectedDefinition.AreaSummary, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}" TextWrapping="Wrap" />
        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Units" />
        <TextBlock Text="{Binding SelectedDefinition.UnitName, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}" />
        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Datum" />
        <TextBlock Text="{Binding SelectedDefinition.DatumName, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}" />
        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Zone" />
        <TextBlock Text="{Binding SelectedDefinition.ZoneLabel, RelativeSource={RelativeSource AncestorType=controls:CrsPickerControl}}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
