<UserControl x:Class="RevitGeoSuite.SharedUI.Controls.MapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
  <Grid>
    <Border Background="#FFFDF9" BorderBrush="#D7D0C2" BorderThickness="1" CornerRadius="6">
      <wv2:WebView2 x:Name="MapBrowser" />
    </Border>
    <Border x:Name="FallbackOverlay" Background="#FFF6F1" BorderBrush="#B7604B" BorderThickness="1" CornerRadius="6" Padding="16" Visibility="Collapsed">
      <TextBlock x:Name="FallbackText" TextWrapping="Wrap" />
    </Border>
  </Grid>
</UserControl>
