<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="SuiteInkColor">#1F2A37</Color>
  <Color x:Key="SuiteAccentColor">#0C6E6E</Color>
  <Color x:Key="SuitePaperColor">#F5F1E8</Color>
  <Color x:Key="SuiteBorderColor">#CFC6B5</Color>
  <Color x:Key="SuiteWarningColor">#8F3D2E</Color>

  <SolidColorBrush x:Key="SuiteInkBrush" Color="{StaticResource SuiteInkColor}" />
  <SolidColorBrush x:Key="SuiteAccentBrush" Color="{StaticResource SuiteAccentColor}" />
  <SolidColorBrush x:Key="SuitePaperBrush" Color="{StaticResource SuitePaperColor}" />
  <SolidColorBrush x:Key="SuiteBorderBrush" Color="{StaticResource SuiteBorderColor}" />
  <SolidColorBrush x:Key="SuiteWarningBrush" Color="{StaticResource SuiteWarningColor}" />

  <Style TargetType="Window">
    <Setter Property="Background" Value="{StaticResource SuitePaperBrush}" />
    <Setter Property="Foreground" Value="{StaticResource SuiteInkBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI" />
  </Style>

  <Style TargetType="GroupBox">
    <Setter Property="Margin" Value="0,0,0,12" />
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="Margin" Value="0,0,8,0" />
    <Setter Property="Padding" Value="14,8" />
    <Setter Property="Background" Value="{StaticResource SuiteAccentBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{StaticResource SuiteAccentBrush}" />
  </Style>

  <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
    <Setter Property="Background" Value="#EFE6D4" />
    <Setter Property="Foreground" Value="{StaticResource SuiteInkBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource SuiteBorderBrush}" />
  </Style>

  <Style x:Key="WarningBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="#FFF1EB" />
    <Setter Property="BorderBrush" Value="{StaticResource SuiteWarningBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="12" />
  </Style>
</ResourceDictionary>
