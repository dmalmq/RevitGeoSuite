<Window x:Class="RevitGeoSuite.MeshInspector.MeshInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:RevitGeoSuite.SharedUI.Controls;assembly=RevitGeoSuite.SharedUI"
        Title="Mesh Inspector"
        Height="860"
        Width="1180"
        MinWidth="980"
        MinHeight="700"
        Loaded="OnLoaded"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/RevitGeoSuite.SharedUI;component/Styles/SuiteTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
      <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding WindowTitle}" />
      <TextBlock Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" Text="{Binding DocumentTitle}" />
      <TextBlock Margin="0,4,0,0" Foreground="#5C6670" Text="Inspect mesh around the canonical survey origin or the project base point without changing CRS, origin, or orientation facts." TextWrapping="Wrap" />
      <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="280" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock FontWeight="SemiBold" Text="Reference Source" />
          <ComboBox Margin="0,8,12,0"
                    ItemsSource="{Binding ReferenceSourceOptions}"
                    SelectedItem="{Binding SelectedReferenceSourceOption, Mode=TwoWay}"
                    DisplayMemberPath="Title"
                    SelectionChanged="OnReferenceSourceSelectionChanged" />
        </StackPanel>
        <TextBlock Grid.Column="1" Margin="0,24,0,0" Foreground="#5C6670" Text="{Binding ReferenceSourceDescription}" TextWrapping="Wrap" />
      </Grid>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Style="{StaticResource SecondaryButtonStyle}" Content="Copy Mesh" Click="OnCopyPrimaryMeshClick" IsEnabled="{Binding CanCopyPrimaryMeshCode}" />
      <Button Content="Save Canonical Mesh" Click="OnSavePrimaryMeshClick" IsEnabled="{Binding CanSavePrimaryMeshCode}" />
      <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close" Click="OnCloseClick" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Padding="12" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9" Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}">
          <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>

        <Border Margin="0,12,0,0" Padding="12" CornerRadius="6" BorderBrush="#B8D1C6" BorderThickness="1" Background="#F4FBF7" Visibility="{Binding HasActionMessage, Converter={StaticResource BoolToVisibilityConverter}}">
          <TextBlock Text="{Binding ActionMessage}" TextWrapping="Wrap" />
        </Border>

        <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <Border Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding ReferenceSourceTitle}" />
                <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="{Binding PrimaryMeshCode}" />
                <TextBlock Margin="0,10,0,0" Foreground="#5C6670" Text="When Survey Point / Canonical Origin is selected, saving updates GeoProjectInfo.PrimaryMeshCode. Project Base Point inspection stays read-only so the shared mesh key remains canonical." TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Summary" />
                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DetailRows}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="170" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                        <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Neighbor Meshes" />
                <TextBlock Margin="0,8,0,10" Foreground="#5C6670" Text="The list below shows the eight adjacent tertiary meshes around the selected reference cell." TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding NeighborMeshCodes}" Visibility="{Binding HasNeighborMeshCodes, Converter={StaticResource BoolToVisibilityConverter}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,8,8" Padding="8,6" CornerRadius="4" BorderBrush="#D7D0C2" BorderThickness="1" Background="#F7F5F0">
                        <TextBlock FontFamily="Consolas" Text="{Binding}" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="#5C6670" Text="Neighbor meshes are not available until the selected reference can be resolved." TextWrapping="Wrap" Visibility="{Binding HasNoNeighborMeshCodes, Converter={StaticResource BoolToVisibilityConverter}}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Grid.Column="2">
            <TextBlock FontWeight="SemiBold" Text="Mesh Grid Overlay" />
            <TextBlock Margin="0,6,0,12" Foreground="#5C6670" Text="The overlay uses the shared Leaflet map host. The blue polygon is the selected mesh cell and the grey polygons are the eight neighbors." TextWrapping="Wrap" />
            <shared:MapControl x:Name="MeshMap" Height="620" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
