<Window x:Class="RevitGeoSuite.Validation.ValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:coreValidation="clr-namespace:RevitGeoSuite.Core.Validation;assembly=RevitGeoSuite.Core"
        Title="Check Project"
        Height="800"
        Width="1120"
        MinWidth="960"
        MinHeight="680"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/RevitGeoSuite.SharedUI;component/Styles/SuiteTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="18">
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
      <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding WindowTitle}" />
      <TextBlock Margin="0,6,0,0" FontSize="16" FontWeight="SemiBold" Text="{Binding DocumentTitle}" />
      <TextBlock Margin="0,4,0,0" Foreground="#5C6670" Text="Review shared project geo health, suspicious conditions, and a derived readiness summary for later mesh and export workflows." TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Style="{StaticResource SecondaryButtonStyle}" Content="Close" Click="OnCloseClick" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Padding="12" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
          <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding StatusTitle}" />
            <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Grid Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
            <StackPanel>
              <TextBlock FontWeight="SemiBold" Text="Shared Metadata Snapshot" />
              <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DetailRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                      <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <StackPanel Grid.Column="2">
            <Border Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Validation Findings" />
                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Findings}" Visibility="{Binding HasFindings, Converter={StaticResource BoolToVisibilityConverter}}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type coreValidation:ValidationResult}">
                      <Border Margin="0,0,0,8" Padding="10" CornerRadius="4" BorderBrush="#D7D0C2" BorderThickness="1" Background="#F7F5F0">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Text="{Binding Severity}" />
                          <TextBlock Margin="0,4,0,0" Text="{Binding Message}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Foreground="#5C6670" Text="No validation findings were produced for the current shared geo state." Visibility="{Binding HasNoFindings, Converter={StaticResource BoolToVisibilityConverter}}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Margin="0,14,0,0" Padding="14" CornerRadius="6" BorderBrush="#D7D0C2" BorderThickness="1" Background="#FFFDF9">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Export Readiness" />
                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding ExportReadinessTitle}" />
                <TextBlock Margin="0,4,0,12" Foreground="#5C6670" Text="{Binding ExportReadinessMessage}" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding ExportReadinessItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,8" Padding="10" CornerRadius="4" BorderBrush="#D7D0C2" BorderThickness="1" Background="#F7F5F0">
                        <StackPanel>
                          <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                          <TextBlock Margin="0,4,0,0" Text="{Binding StatusText}" />
                          <TextBlock Margin="0,4,0,0" Foreground="#5C6670" Text="{Binding Detail}" TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>

